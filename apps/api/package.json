{
  "name": "api",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsup src/index.ts --watch --format esm --onSuccess 'npm run start'",
    "build": "tsup src/index.ts --format esm --clean",
    "start": "node dist/index.js",
    "lint": "eslint . --fix",
    "format": "prettier --write .",
    "deps": "bun x taze@latest --interactive",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "dotenv": "^17.3.1",
    "hono": "^4.12.5"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "eslint": "^9.39.3",
    "eslint-plugin-n": "^17.24.0",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  }
}
